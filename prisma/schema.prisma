generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Plan {
  FREE
  PRO
}

model User {
  id                         String   @id @default(cuid())
  email                      String   @unique
  name                       String?
  plan                       Plan     @default(FREE)
  tokensUsed                 Int      @default(0)
  usagePeriodStart           DateTime @default(now())
  lemonSqueezyCustomerId     String?
  lemonSqueezySubscriptionId String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  libraries Library[]
  libraryMemberships LibraryMember[]
  sentLibraryInvites LibraryInvite[] @relation("InvitedBy")
  receivedLibraryInvites LibraryInvite[] @relation("Invitee")
  folders   Folder[]
  pages     Page[]
  documents Document[]
  apiKeys   ApiKey[]
  pagePresence PagePresence[]
  pageVersions PageVersion[]
  recallChatSessions RecallChatSession[]
}

model Library {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("📚")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders   Folder[]
  pages     Page[]
  documents Document[]
  apiKeys   ApiKey[]
  members   LibraryMember[]
  invites   LibraryInvite[]
  recallChatSessions RecallChatSession[]

  @@index([userId])
}

enum LibraryRole {
  EDITOR
  VIEWER
}

model LibraryMember {
  id        String      @id @default(cuid())
  libraryId String
  userId    String
  role      LibraryRole @default(EDITOR)
  createdAt DateTime    @default(now())

  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([libraryId, userId])
  @@index([userId])
  @@index([libraryId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model LibraryInvite {
  id          String       @id @default(cuid())
  libraryId   String
  email       String
  userId      String?
  role        LibraryRole  @default(EDITOR)
  status      InviteStatus @default(PENDING)
  token       String       @unique @default(cuid())
  message     String?
  invitedById String
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  library   Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  user      User?   @relation("Invitee", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([libraryId, email])
  @@index([userId, status])
  @@index([email, status])
  @@index([libraryId, status])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("gray")
  userId    String
  libraryId String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  library  Library    @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  parent   Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[]   @relation("FolderTree")
  pages    Page[]
  documents Document[]

  @@index([userId])
  @@index([libraryId])
  @@index([parentId])
}

model Page {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   Json     @default("{}")
  plainText String   @default("") @db.Text
  userId    String
  libraryId String
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks  Chunk[]
  presence PagePresence[]
  versions PageVersion[]

  @@index([userId])
  @@index([libraryId])
  @@index([folderId])
}

model PagePresence {
  pageId   String
  userId   String
  name     String?
  email    String
  lastSeen DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pageId, userId])
  @@index([pageId])
}

model PageVersion {
  id            String   @id @default(cuid())
  pageId        String
  title         String
  content       Json
  plainText     String   @db.Text
  createdById   String
  createdByName String?
  createdAt     DateTime @default(now())

  page      Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt(sort: Desc)])
  @@index([createdById])
}

model RecallChatSession {
  id        String   @id @default(cuid())
  userId    String
  libraryId String
  scopeKey  String
  title     String?
  turns     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([userId, libraryId, scopeKey, updatedAt(sort: Desc)])
  @@index([libraryId])
}

enum DocumentType {
  NOTE
  PDF
  SLIDES
  DOC
  CODE
  IMAGE
  SHEET
  ARCHIVE
  AUDIO
  VIDEO
  WHITEBOARD
  DECK
  OTHER
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

model Document {
  id           String         @id @default(cuid())
  title        String
  type         DocumentType   @default(OTHER)
  status       DocumentStatus @default(READY)
  mimeType     String?
  storagePath  String?
  sizeBytes    Int?
  content      String         @default("") @db.Text
  // Native editable canvas scene (whiteboard). Null for uploaded files.
  // Per-element edit locks are ephemeral (Redis, see src/lib/boards/board-locks.ts),
  // not stored here.
  boardContent Json?
  // Native editable slideshow scene (DECK type). Flat, id-keyed slide/element
  // maps; see src/lib/decks/deck-schema.ts. Null for non-deck documents.
  deckContent  Json?
  language     String?
  userId       String
  libraryId    String
  folderId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks  Chunk[]

  @@index([userId])
  @@index([libraryId])
  @@index([folderId])
}

enum ChunkSourceType {
  PAGE
  DOCUMENT
}

model Chunk {
  id         String          @id @default(cuid())
  sourceType ChunkSourceType
  pageId     String?
  documentId String?
  content    String          @db.Text
  chunkIndex Int             @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime        @default(now())

  page     Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([documentId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  libraryId  String?
  name       String
  keyPrefix  String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  library Library? @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([libraryId])
}
